# web-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env

# --- Optional: server behavior ---
# No credentials are required for the fetch toolset.

# User-Agent sent on outbound requests (default: web-mcp).
# WEB_USER_AGENT=web-mcp

# Cap on returned response body size, in bytes (default: 1048576).
# WEB_MAX_BYTES=1048576

# Comma-separated toolset names to enable, or "all" (default).
WEB_TOOLSETS=all

# "true" exposes only read-only tools.
WEB_READONLY=false
